max-visible=8
sort=-time
anchor=bottom-right
layer=top

font=Inter 10
markup=1
format=<b>%s</b>\n%b
text-alignment=left

width=300
height=300
margin=10
padding=20
border-size=2
border-radius=2
border-color=#28344a
background-color=#101419
text-color=#a9b1d6
progress-color=over #28344a

icons=1
max-icon-size=32
icon-path=/usr/share/icons/Papirus/32x32/status:/usr/share/icons/Papirus/32x32/devices:/usr/share/icons/Papirus/32x32/apps:/usr/share/icons/Papirus/32x32/places:/usr/share/icons/Papirus/32x32/actions:/usr/share/icons/Papirus/32x32/emblems:/usr/share/icons/Papirus/32x32/emotes:/usr/share/icons/Papirus/32x32/mimetypes

default-timeout=10000
ignore-timeout=1
group-by=none

on-button-left=invoke-default-action
on-button-middle=none
on-button-right=dismiss

[urgency=low]
default-timeout=10000

[urgency=critical]
text-color=#FFB300
default-timeout=0
layer=top

[category=battery-normal]
text-color=#76B97F

[category=battery-critical]
text-color=#E05F65

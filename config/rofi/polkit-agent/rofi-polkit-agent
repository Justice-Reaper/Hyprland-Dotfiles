#!/bin/sh
set -eu

(builtin unset HISTFILE) 2>/dev/null || true

main() {
    local runtime_dir
    local lock_file
    local lock_timeout

    runtime_dir="/run/user/$(id -u)"
    if [ ! -d "$runtime_dir" ]; then
        runtime_dir="$(mktemp -d)"
        trap 'rm -rf "$runtime_dir"' EXIT
    fi

    lock_file="$runtime_dir/rofi-polkit-agent.lock"
    lock_timeout=30

    if [ $# -gt 0 ]; then
        local all_args
        all_args="$*"
        case "$all_args" in
        'h'|'help'|'-h'|'-help'|'--help')
            echo 'Usage: rofi-polkit-agent [ROFI_OPTIONS]... Polkit agent using rofi for GUI.
  Start the polkit agent, with default options:
  rofi-polkit-agent
  Start the polkit agent, with any additional argument passed directly to rofi:
  rofi-polkit-agent -theme PATH -monitor NUM '
            return 0
            ;;
        esac
    fi

    acquire_lock() {
        local start_time
        local current_time
        local lock_time
        local lock_pid

        start_time=$(date +%s)

        while ! mkdir "$lock_file" 2>/dev/null; do
            if [ -f "$lock_file/timestamp" ] && [ -f "$lock_file/pid" ]; then
                lock_time=$(cat "$lock_file/timestamp")
                lock_pid=$(cat "$lock_file/pid")
                current_time=$(date +%s)

                if ! kill -0 "$lock_pid" 2>/dev/null; then
                    rm -rf "$lock_file"
                    continue
                fi

                if [ $((current_time - lock_time)) -gt "$lock_timeout" ]; then
                    rm -rf "$lock_file"
                    continue
                fi
            fi

            current_time=$(date +%s)
            if [ $((current_time - start_time)) -gt 5 ]; then
                return 1
            fi

            sleep 0.1
        done

        echo "$$" > "$lock_file/pid"
        date +%s > "$lock_file/timestamp"
        chmod 700 "$lock_file"

        return 0
    }

    release_lock() {
        if [ -d "$lock_file" ]; then
            if [ -f "$lock_file/pid" ] && [ "$(cat "$lock_file/pid")" = "$$" ]; then
                rm -rf "$lock_file"
            fi
        fi
    }

    cleanup() {
        release_lock
    }

    if [ "$#" -gt 0 ] && [ "$1" = "_CALLED_INTERNALLY" ]; then
        shift 1

        local msg
        local info_text=""
        while IFS= read -r msg; do
            if printf '%s' "$msg" | jq -e '.action == "show info"' >/dev/null 2>&1; then
                local text
                text="$(printf '%s' "$msg" | jq -r '.text // ""')"
                if [ -n "$info_text" ]; then
                    info_text="$info_text\n$text"
                else
                    info_text="$text"
                fi
                continue
            fi

            if printf '%s' "$msg" | jq -e '.action == "request password"' >/dev/null 2>&1; then
                if ! acquire_lock; then
                    printf '{"action":"cancel","reason":"Authentication already in progress or system busy"}\n'
                    continue
                fi

                trap cleanup EXIT INT TERM HUP QUIT

                local prompt
                local message
                local response
                local timeout_cmd

                prompt="$(printf '%s' "$msg" | jq -r '.prompt // "Password:"')"
                message="$(printf '%s' "$msg" | jq -r '
                    .message // "No message given!" as $top |
                    if .["polkit action"] != null then
                        .["polkit action"] as $p |
                        [
                            "<b>Description:</b> " + ($p.description     // ""),
                            "<b>Vendor:</b> " + ($p["vendor name"]  // ""),
                            "<b>Action ID:</b> " + ($p.id              // ""),
                            ""
                        ] | map(select(length > (. | split("</b> ")[0] | length + 5))) |
                        join("\n")
                    else $top end
                ')"

                if [ -n "$info_text" ]; then
                    info_oneline="$(printf '%b' "$info_text" | tr '\n' ' ' | sed 's/\.//g')"
                    message="$(printf '<b>Authentication:</b> %s\n%s' "$info_oneline" "$message")"
                    info_text=""
                fi

                response=""
                timeout_cmd=""
                if command -v timeout >/dev/null 2>&1; then
                    timeout_cmd="timeout $lock_timeout"
                fi

                if [ -n "$timeout_cmd" ]; then
                    response="$(printf '' | $timeout_cmd rofi -x11 -normal-window -dmenu -p "Password " \
                        -markup-rows -mesg "$message" -password -no-fixed-num-lines "$@" || true)"
                else
                    response="$(printf '' | rofi -x11 -normal-window -dmenu -p "Password " \
                        -markup-rows -mesg "$message" -password -no-fixed-num-lines "$@" || true)"
                fi

                if [ -z "$response" ]; then
                    printf '{"action":"cancel"}\n'
                else
                    printf '{"action":"authenticate","password":%s}\n' "$(printf '%s' "$response" | jq -R .)"
                    response="$(dd if=/dev/urandom bs=64 count=1 2>/dev/null | base64 || echo "XXXXXXXXXXXXXXXXXXXX")"
                    unset response
                fi

                release_lock
                trap - EXIT INT TERM HUP QUIT

            elif printf '%s' "$msg" | jq -e '.action == "authorization response"' >/dev/null 2>&1; then
                authorized="$(printf '%s' "$msg" | jq -r '.authorized')"
                if [ "$authorized" = "false" ]; then
                    rofi -x11 -normal-window -e '<span color="#E05F65">Authentication failed</span>' -markup "$@" || true
                fi
            fi
        done
    else
        local quoted_args
        quoted_args=""
        local arg
        for arg in "$@"; do
            quoted_args="$quoted_args $(printf '%q' "$arg")"
        done

        exec cmd-polkit-agent -s -q -c "$0 _CALLED_INTERNALLY$quoted_args"
    fi
}

main "$@"

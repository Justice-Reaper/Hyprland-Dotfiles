#!/bin/bash

scope_file="/home/user_replace/.config/bin/scope"
script_name="add-asset-to-scope"

usage() {
    echo "Usage: $script_name [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  -a, --assets ASSET1 ASSET2 ...    Add one or more assets directly"
    echo "  -f, --file FILE                   Add assets from a file (one per line)"
    echo "  -h, --help                        Show this help message"
    echo ""
    echo "Examples:"
    echo "  $script_name -a 10.10.10.1 example.com"
    echo "  $script_name -f targets.txt"
    echo ""
    exit 1
}

[[ "$#" -eq 0 ]] && usage

add_asset() {
    local asset="$1"
    if grep -qxF "$asset" "$scope_file"; then
        echo "WARNING: '$asset' already in scope, skipping"
    else
        echo "$asset" >> "$scope_file"
    fi
}

case "$1" in
    -a|--assets)
        shift
        [[ "$#" -eq 0 ]] && usage
        for asset in "$@"; do
            add_asset "$asset"
        done
        ;;
    -f|--file)
        [[ -z "$2" ]] && usage
        [[ ! -f "$2" ]] && echo "ERROR: file not found: $2" >&2 && exit 1
        while IFS= read -r asset; do
            [[ -z "$asset" ]] && continue
            add_asset "$asset"
        done < "$2"
        ;;
    -h|--help)
        usage
        ;;
    *)
        usage
        ;;
esac

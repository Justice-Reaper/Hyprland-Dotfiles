#!/bin/bash

versions=$(archlinux-java status | tail -n +2 | awk '{print $1}')
current=$(archlinux-java status | grep '(default)' | awk '{print $1}')

echo -e "Active version: ${current:-none}\n"

select version in $versions "Quit"; do
    if [ "$version" = "Quit" ]; then
        break
    fi
    if [ -n "$version" ]; then
        sudo archlinux-java set "$version"
        break
    fi
done

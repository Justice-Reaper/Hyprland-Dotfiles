#!/bin/bash

script_name="remove-asset-from-scope"
file="/home/user_replace/.config/bin/scope"

usage() {
    echo "Usage: $script_name [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  -a, --assets ASSET1 ASSET2 ...    Remove one or more assets directly"
    echo "  -f, --file FILE                   Remove assets from a file (one per line)"
    echo "  -c, --clear                       Clear all assets from scope"
    echo "  -h, --help                        Show this help message"
    echo ""
    echo "Examples:"
    echo "  $script_name -a 10.10.10.1 example.com"
    echo "  $script_name -f targets.txt"
    echo "  $script_name -c"
    echo ""
    exit 1
}

[[ "$#" -eq 0 ]] && usage

remove_asset() {
    local asset="$1"
    if grep -qxF "$asset" "$file"; then
        sed -i "/^${asset}$/d" "$file"
    else
        echo "WARNING: '$asset' not found in scope, skipping"
    fi
}

case "$1" in
    -a|--assets)
        shift
        [[ "$#" -eq 0 ]] && usage
        for asset in "$@"; do
            remove_asset "$asset"
        done
        ;;
    -f|--file)
        [[ -z "$2" ]] && usage
        [[ ! -f "$2" ]] && echo "ERROR: file not found: $2" >&2 && exit 1
        while IFS= read -r asset; do
            [[ -z "$asset" ]] && continue
            remove_asset "$asset"
        done < "$2"
        ;;
    -c|--clear)
        > "$file"
        ;;
    -h|--help)
        usage
        ;;
    *)
        usage
        ;;
esac

#!/bin/bash

script_name="nmcli-connect-device"

if [[ -z "$1" ]]; then
    echo "Usage: $script_name <interface> [ssid] [password] [--hidden]"
    exit 1
fi

type=$(nmcli -g GENERAL.TYPE dev show "$1" 2>/dev/null)

if [[ "$type" != "wifi" ]]; then
    nmcli device connect "$1"
    exit
fi

args=(dev wifi connect "$2" ifname "$1")

if [[ -n "$3" ]]; then
    args+=(password "$3")
fi

if [[ "$4" == "--hidden" ]]; then
    args+=(hidden yes)
fi

nmcli "${args[@]}"
